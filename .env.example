# Cloudera Data Warehouse Virtual Warehouse connection
HIVE_HOST=your-vw-host.dw.cloudera.site
HIVE_PORT=443
HIVE_HTTP_PATH=/cliservice
HIVE_USERNAME=your-workload-user
HIVE_PASSWORD=your-workload-password

# Safety controls
# When true (default), execute_query rejects DDL/DML (DROP/INSERT/UPDATE/...).
HIVE_READ_ONLY=true
# Max rows returned by execute_query. Prevents a runaway scan from blowing up
# the calling agent's context window.
HIVE_QUERY_ROW_LIMIT=1000
